# Copy to .env and adjust values for local development

# Database
DATABASE_URL=postgresql://funded_shield:funded_shield@localhost:5432/funded_shield

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Backend
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
# Comma-separated admin emails for /api/v1/admin/* endpoints
ADMIN_EMAILS=["admin@example.com"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
